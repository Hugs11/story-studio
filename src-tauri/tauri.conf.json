{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Story Studio",
  "version": "0.9.1",
  "identifier": "com.hugs11.story-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Story Studio",
        "width": 1100,
        "height": 680,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "maximizable": true,
        "maximized": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost blob:; img-src 'self' asset: https://asset.localhost blob: data:; media-src 'self' asset: https://asset.localhost blob:; script-src 'self' blob:; worker-src blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../LICENSE": "LICENSE",
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md",
      "tools/ffmpeg.exe": "tools/ffmpeg.exe",
      "tools/7z.exe": "tools/7z.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
